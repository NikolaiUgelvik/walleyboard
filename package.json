{
  "name": "@walleyboard/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:cli": "npm --workspace walleyboard run build",
    "sizecheck": "node scripts/check-production-file-sizes.mjs",
    "test": "WALLEYBOARD_SKIP_STARTUP_DOCKER_CLEANUP=1 node --import tsx --test 'apps/**/*.test.ts' 'apps/**/*.test.tsx' 'packages/**/*.test.ts' 'packages/**/*.test.tsx'",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run sizecheck && npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "postinstall": "node scripts/fix-node-pty-permissions.mjs",
    "prepare": "husky",
    "dev:backend": "npm --workspace @walleyboard/backend run dev",
    "dev:web": "npm --workspace @walleyboard/web run dev",
    "db:generate": "drizzle-kit generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "drizzle-kit": "^0.31.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "esbuild": "^0.27.4"
  },
  "engines": {
    "node": ">=22"
  }
}
