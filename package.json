{
  "name": "orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "dev:backend": "npm --workspace @orchestrator/backend run dev",
    "dev:web": "npm --workspace @orchestrator/web run dev",
    "db:generate": "drizzle-kit generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22"
  }
}
