{
  "name": "walleyboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "sizecheck": "node scripts/check-production-file-sizes.mjs",
    "test": "node --import tsx --test apps/backend/src/lib/*.test.ts apps/backend/src/routes/*.test.ts apps/web/src/**/*.test.ts apps/web/src/**/*.test.tsx",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run sizecheck && npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "prepare": "husky",
    "dev:backend": "npm --workspace @walleyboard/backend run dev",
    "dev:web": "npm --workspace @walleyboard/web run dev",
    "db:generate": "drizzle-kit generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "drizzle-kit": "^0.31.0",
    "husky": "^9.1.7",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "esbuild": "^0.27.4"
  },
  "engines": {
    "node": ">=22"
  }
}
