{
  "name": "@walleyboard/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
