{
  "name": "@walleyboard/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src vite.config.ts",
    "format": "biome format --write src vite.config.ts"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.10",
    "@mantine/core": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@tanstack/react-query": "^5.66.0",
    "@walleyboard/contracts": "0.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
