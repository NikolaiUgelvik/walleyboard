    "@pierre/diffs": "^1.1.10",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.66.0",
    "@walleyboard/contracts": "0.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
