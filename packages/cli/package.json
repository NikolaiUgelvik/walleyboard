{
  "name": "walleyboard",
  "version": "0.1.1",
  "description": "Local-first WalleyBoard workbench launcher",
  "license": "MIT",
  "type": "module",
  "bin": {
    "walleyboard": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "prepack": "WALLEYBOARD_FORCE_WEB_BUILD=1 node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolaiUgelvik/walleyboard.git"
  },
  "bugs": {
    "url": "https://github.com/NikolaiUgelvik/walleyboard/issues"
  },
  "homepage": "https://github.com/NikolaiUgelvik/walleyboard#readme",
  "publishConfig": {
    "access": "public"
  }
}
